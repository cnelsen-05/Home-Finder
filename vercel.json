{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ],
  "functions": {
    "api/index.py": {
      "excludeFiles": "{.git/**,.pytest_cache/**,.ruff_cache/**,.venv/**,tests/**,data/cache/**,data/exports/**,data/raw/**,data/reports/**,data/*.db,**/__pycache__/**}"
    }
  }
}
