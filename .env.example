# Local database path. Keep this private; it may contain home-search notes.
REAL_ESTATE_DB_PATH=data/realestate.db

# Hosted database URL. Set one of these in Vercel when using Supabase/Postgres.
# Required for hosted Vercel use; local dev falls back to REAL_ESTATE_DB_PATH.
# For Supabase, use the Postgres connection string with SSL enabled.
DATABASE_URL=
POSTGRES_URL=

# Serverless pool behavior. "null" opens short-lived DB connections, which is
# safest for Vercel + Supabase free-tier style usage. Leave blank for defaults.
HOMEANALYZE_DB_POOL=

# Shared household profiles shown in the map UI. These are app-level profiles
# for ratings/notes; full Supabase Auth user mapping can be added later.
HOMEANALYZE_HOUSEHOLD_NAME=Home Search
HOMEANALYZE_PROFILE_NAMES=Adult 1,Adult 2

# Private hosted access. Set HOMEANALYZE_ACCESS_CODE in Vercel before sharing
# the generated vercel.app URL.
HOMEANALYZE_ACCESS_CODE=
HOMEANALYZE_AUTH_SECRET=

# Optional geocoding/routing providers. Disabled unless configured.
GOOGLE_MAPS_API_KEY=
MAPBOX_ACCESS_TOKEN=
OPENROUTESERVICE_API_KEY=
TRAVELTIME_APP_ID=
TRAVELTIME_API_KEY=

# Optional MLS Grid / NorthstarMLS-style OData access. Disabled unless licensed.
MLS_GRID_BASE_URL=
MLS_GRID_TOKEN=

# Optional public/commercial parcel providers. Disabled unless credentials and rights exist.
REGRID_API_KEY=
ATTOM_API_KEY=
ESTATED_API_KEY=
HOUSECANARY_API_KEY=

# Optional LLM provider. Core scoring remains deterministic without this.
OPENAI_API_KEY=
LOCAL_LLM_BASE_URL=
